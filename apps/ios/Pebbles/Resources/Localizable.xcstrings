    "Every moment matters — the big ones and the quiet ones. But most of them slip away before you even notice. Pebbles helps you collect them, one by one." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every moment matters — the big ones and the quiet ones. But most of them slip away before you even notice. Pebbles helps you collect them, one by one."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque moment compte : autant les grands que les discrets. Ne les laisse plus s’échapper : Pebbles t’aide à les collecter, un par un."
          }
        }
      }
    },
    "Get your pebble." : {
      "extractionState" : "manual",
      "localizations" : {
